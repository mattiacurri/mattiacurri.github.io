---
import Layout from '../components/Layout.astro';
import cv from '../data/cv.json';
import { LINKS } from '../consts';
---

<Layout>
  <section class="hero">
    <div class="hero-content">
      <h1>Mattia Curri</h1>
      <p class="tagline">{cv.tagline}</p>
      <p class="about">{cv.about}</p>
      <div class="hero-links">
        <a href={LINKS.github} aria-label="GitHub"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg></a>
        <a href={LINKS.linkedin} aria-label="LinkedIn"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
        <a href={LINKS.twitter} aria-label="X"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href={`mailto:${cv.email}`} aria-label="Email"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></a>
        <a href={LINKS.youtube} aria-label="YouTube"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
      </div>
    </div>
  </section>

  <div class="item-grid">
    <section class="section">
      <h2>Education</h2>
      {cv.education.map((edu) => (
        <div class="entry">
          <div class="entry-header">
            <strong>{edu.degree}</strong>
            <span class="entry-meta">{edu.school} · {edu.period}</span>
          </div>
          <p class="entry-note">{edu.note}</p>
          {edu.thesis && <p class="entry-thesis">Thesis: {edu.thesis}</p>}
          {edu.courses && (
            <div class="tags">
              {edu.courses.map((c: string) => <span class="tag">{c}</span>)}
            </div>
          )}
        </div>
      ))}

      <h2>Publications</h2>
      {cv.publications.map((pub) => (
        <div class="entry">
          <div class="entry-header">
            <strong>{pub.title}</strong>
            <a href={pub.url} class="pub-pdf" aria-label="PDF">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </a>
          </div>
          <p class="entry-note">{pub.note} — {pub.venue}</p>
        </div>
      ))}
    </section>

    <section class="section">
      <h2>Projects</h2>
      {cv.projects.map((p) => (
        <div class="entry">
          <div class="entry-header">
            <strong><a href={p.url}>{p.name}</a></strong>
          </div>
          <p class="entry-note">{p.desc}</p>
          <div class="tags">
            {p.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </section>
  </div>

  <section class="section">
    <h2>Achievements</h2>
    {cv.achievements.map((a) => (
      <div class="entry">
        <div class="entry-header">
          <strong><a href={a.url}>{a.title}</a></strong>
          <span class="entry-meta">{a.date}</span>
        </div>
        <p class="entry-note">{a.note}</p>
        {a.tags && (
          <div class="tags">
            {a.tags.map((t: string) => <span class="tag">{t}</span>)}
          </div>
        )}
      </div>
    ))}
  </section>

  <section class="section">
    <h2>Additional</h2>
    <p>{cv.languages.join(' · ')}</p>
  </section>
</Layout>
