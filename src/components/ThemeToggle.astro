<button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
  <svg class="theme-icon" id="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <svg class="theme-icon" id="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position:absolute;opacity:0;transform:rotate(-90deg) scale(0.5)">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .theme-icon {
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    background: var(--ripple-color, #0d0d0d);
    clip-path: circle(0% at 50% 50%);
    opacity: 0;
  }

  body.animating-theme::after {
    animation: theme-ripple 0.55s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  @keyframes theme-ripple {
    0% {
      opacity: 1;
      clip-path: circle(0% at var(--ripple-x, 50%) var(--ripple-y, 50%));
    }
    50% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      clip-path: circle(150% at var(--ripple-x, 50%) var(--ripple-y, 50%));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    body::after { display: none; }
    .theme-icon {
      transition: opacity 0.15s;
    }
  }
</style>

<script>
  const toggle = document.getElementById('theme-toggle');
  const sun = document.getElementById('sun-icon');
  const moon = document.getElementById('moon-icon');
  const root = document.documentElement;

  let animating = false;

  function setIconState(theme) {
    if (theme === 'dark') {
      sun.style.opacity = '0';
      sun.style.transform = 'rotate(90deg) scale(0.5)';
      moon.style.opacity = '1';
      moon.style.transform = 'rotate(0deg) scale(1)';
    } else {
      moon.style.opacity = '0';
      moon.style.transform = 'rotate(-90deg) scale(0.5)';
      sun.style.opacity = '1';
      sun.style.transform = 'rotate(0deg) scale(1)';
    }
  }

  function setTheme(theme) {
    root.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    setIconState(theme);
  }

  const initial = root.getAttribute('data-theme') || 'light';
  setTheme(initial);

  toggle.addEventListener('click', (e) => {
    if (animating) return;
    animating = true;

    const current = root.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';

    const rect = toggle.getBoundingClientRect();
    const x = rect.left + rect.width / 2;
    const y = rect.top + rect.height / 2;

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReduced) {
      setTheme(next);
      animating = false;
      return;
    }

    const rippleColor = next === 'dark' ? '#0d0d0d' : '#f5f4f0';
    root.style.setProperty('--ripple-color', rippleColor);
    root.style.setProperty('--ripple-x', x + 'px');
    root.style.setProperty('--ripple-y', y + 'px');

    document.body.classList.add('animating-theme');

    setTimeout(() => {
      setTheme(next);
    }, 240);

    setTimeout(() => {
      document.body.classList.remove('animating-theme');
      animating = false;
    }, 580);
  });
</script>
